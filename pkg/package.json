{
  "name": "recordingnotes",
  "version": "0.1.0",
  "description": "Minimalist podcast note-taking system",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test DB_PATH=test.db node --test test/*.test.js",
    "init-db": "node init-db.js",
    "db:reset": "rm -f dev.db && node init-db.js"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "localtunnel": "^2.0.2",
    "nodemon": "^3.0.1"
  }
}
